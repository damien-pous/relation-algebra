DECLARE PLUGIN "rocq-relation-algebra.mrewrite"

{
  open Ltac_plugin
  open Stdarg
  open Tacarg
  open Mrewrite

let cont k c = Tacinterp.Value.(apply k [of_constr c])
}

TACTIC EXTEND ra_extend_lr
  | [ "ra_extend" tactic(k) "->" constr(h) ] -> { extend (cont k) `LR h } END
TACTIC EXTEND ra_extend_rl 
  | [ "ra_extend" tactic(k) "<-" constr(h) ] -> { extend (cont k) `RL h } END
